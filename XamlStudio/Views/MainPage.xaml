<Page x:Class="XamlStudio.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:CommunityToolkit.WinUI.Controls"
      xmlns:converters="using:CommunityToolkit.WinUI.Converters"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ex="using:CommunityToolkit.WinUI"
      xmlns:exf="using:CommunityToolkit.WinUI.Extensions.Future"
      xmlns:future="using:CommunityToolkit.WinUI.Controls.Future"
      xmlns:lcontrols="using:XamlStudio.Controls"
      xmlns:local="using:XamlStudio.Views"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:models="using:XamlStudio.Models"
      xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
      xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
      xmlns:ui="using:CommunityToolkit.WinUI"
      Style="{StaticResource PageStyle}"
      mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <local:DocumentToViewModelConverter x:Key="DocumentToViewModelConverter" MainViewModel="{x:Bind ViewModel}" />

            <MenuFlyout x:Key="TabItemFlyout">
                <MenuFlyoutItem x:Uid="MainPage_Tab_Menu_Duplicate"
                                Command="{x:Bind ViewModel.DuplicateDocumentCommand}"
                                Icon="Copy" />
            </MenuFlyout>
        </ResourceDictionary>
    </Page.Resources>


    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Activity Bar w/ Modern Navigation View on Left  -->
        <muxc:NavigationView x:Name="NavMenu"
                             Grid.RowSpan="2"
                             AutomationProperties.LandmarkType="Navigation"
                             HighContrastAdjustment="None"
                             IsBackButtonVisible="Collapsed"
                             IsPaneToggleButtonVisible="False"
                             IsSettingsVisible="False"
                             ItemInvoked="NavMenu_ItemInvoked"
                             SelectionChanged="NavMenu_SelectionChanged"
                             Style="{StaticResource MainNavigationViewStyle}">
            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem x:Uid="MainPage_NavMenu_Explorer" Tag="EXPLORER">
                    <muxc:NavigationViewItem.Icon>
                        <lcontrols:AppFontIcon IconName="Copy" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem x:Uid="MainPage_NavMenu_DataSources"
                                         IsEnabled="{x:Bind ViewModel.IsEditingDocument, Mode=OneWay}"
                                         Tag="DATASOURCES">
                    <muxc:NavigationViewItem.Icon>
                        <lcontrols:AppFontIcon IconName="Wheel" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem x:Uid="MainPage_NavMenu_Debug"
                                         IsEnabled="{x:Bind ViewModel.IsEditingDocument, Mode=OneWay}"
                                         Tag="DEBUG">
                    <muxc:NavigationViewItem.Icon>
                        <lcontrols:AppFontIcon IconName="Bug" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem x:Uid="MainPage_NavMenu_Properties"
                                         IsEnabled="{x:Bind ViewModel.IsEditingDocument, Mode=OneWay}"
                                         Tag="PROPERTIES">
                    <muxc:NavigationViewItem.Icon>
                        <lcontrols:AppFontIcon IconName="Properties" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem x:Uid="MainPage_NavMenu_Toolbox"
                                         IsEnabled="{x:Bind ViewModel.IsEditingDocument, Mode=OneWay}"
                                         Tag="TOOLBOX">
                    <muxc:NavigationViewItem.Icon>
                        <lcontrols:AppFontIcon IconName="Work" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
            </muxc:NavigationView.MenuItems>
            <muxc:NavigationView.FooterMenuItems>
                <muxc:NavigationViewItem x:Name="WelcomeButton"
                                         x:Uid="MainPage_NavMenu_Welcome"
                                         Tag="WELCOME">
                    <muxc:NavigationViewItem.Icon>
                        <lcontrols:AppFontIcon IconName="Home" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="Contribute"
                                         SelectsOnInvoked="False"
                                         Tag="CONTRIBUTE">
                    <muxc:NavigationViewItem.Icon>
                        <PathIcon HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Data="{StaticResource GitHubIcon}"
                                  Opacity="0.6">
                            <PathIcon.RenderTransform>
                                <ScaleTransform CenterX="8" CenterY="20" ScaleX="1.5" ScaleY="1.5" />
                            </PathIcon.RenderTransform>
                        </PathIcon>
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem x:Name="SettingsButton"
                                         x:Uid="MainPage_NavMenu_Settings"
                                         Tag="SETTINGS">
                    <muxc:NavigationViewItem.Icon>
                        <lcontrols:AppFontIcon IconName="Settings" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>

            </muxc:NavigationView.FooterMenuItems>
        </muxc:NavigationView>

        <!--  Primary Side Bar Content, optionally on left besides Activity Bar  -->
        <Grid x:Name="ContentGrid"
              Grid.RowSpan="2"
              Grid.Column="1"
              Width="320"
              MinWidth="200"
              Visibility="{x:Bind local:MainPage.IsSideBarVisible(ViewModel.OpenActivity, ViewModel.IsEditingDocument), Mode=OneWay, FallbackValue=Collapsed}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <controls:ContentSizer Grid.Column="1"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Stretch" />

            <controls:SwitchPresenter x:Name="ToolboxPresenter" Value="{x:Bind ViewModel.OpenActivity, Mode=OneWay}">
                <controls:Case Value="EXPLORER">
                    <local:Explorer MainViewModel="{x:Bind ViewModel}" />
                </controls:Case>
                <controls:Case Value="DATASOURCES">
                    <local:DataSources MainViewModel="{x:Bind ViewModel}" />
                </controls:Case>
                <controls:Case Value="DEBUG">
                    <local:Binding MainViewModel="{x:Bind ViewModel}" />
                </controls:Case>
                <controls:Case Value="PROPERTIES">
                    <local:Properties MainViewModel="{x:Bind ViewModel}" />
                </controls:Case>
                <controls:Case Value="TOOLBOX">
                    <local:Toolbox MainViewModel="{x:Bind ViewModel}" />
                </controls:Case>
                <!--  Debug: Should never see  -->
                <controls:Case IsDefault="True">
                    <Border Background="DarkGray">
                        <TextBlock Margin="16,0,0,0"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Foreground="Black"
                                   Text="{x:Bind ViewModel.OpenActivity}" />
                    </Border>
                </controls:Case>
            </controls:SwitchPresenter>
        </Grid>

        <!--  Rest of Main App Area + TitleBar Content  -->
        <Grid x:Name="TitleBarArea"
              Grid.Column="2"
              ui:FrameworkElementExtensions.EnableActualSizeBinding="true"
              Background="Transparent">
            <Grid.ColumnDefinitions>
                <!--<ColumnDefinition x:Name="LeftPaddingColumn" Width="0"/>-->
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition x:Name="DragBarColumn"
                                  Width="*"
                                  MinWidth="148" />
                <!--  Width of the padding columns is set in LayoutMetricsChanged handler.  -->
                <!--
                    Using padding columns instead of Margin ensures that the background
                    paints the area under the caption control buttons (for transparent buttons).
                -->
                <ColumnDefinition x:Name="RightPaddingColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <!--  Grippable bit of TitleBar  -->
            <Grid x:Name="AppTitleBarSection"
                  Grid.Column="1"
                  Margin="8,0,0,0"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Image Grid.Column="1"
                       Width="16"
                       Height="16"
                       Margin="0,2,0,0"
                       Source="ms-appx:///Assets/AppTitleBar.png" />
                <TextBlock x:Name="AppTitleTextBlock"
                           Grid.Column="2"
                           Margin="8,2,0,0"
                           VerticalAlignment="Center"
                           Style="{StaticResource CaptionTextBlockStyle}" />
            </Grid>

            <!--  TitleBar Content  -->
            <controls:SwitchPresenter Value="{x:Bind ViewModel.OpenActivity, Mode=OneWay}">
                <controls:Case Value="WELCOME">
                    <!--  TODO: File/Folder Search?  -->
                    <Border />
                </controls:Case>
                <controls:Case Value="SETTINGS">
                    <!--  TODO: Settings Search?  -->
                    <Border />
                </controls:Case>
                <!--  Default case showing document  -->
                <controls:Case IsDefault="True">
                    <muxc:TabView x:Name="DocumentTabs"
                                  MaxWidth="{x:Bind local:MainPage.CalculateTabHeaderMaxWidth(TitleBarArea.(ui:FrameworkElementExtensions.ActualWidth), DragBarColumn.MinWidth, RightPaddingColumn.Width.Value), Mode=OneWay}"
                                  Margin="0"
                                  Padding="0"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Stretch"
                                  AddTabButtonCommand="{x:Bind ViewModel.NewDocumentCommand}"
                                  CloseButtonOverlayMode="OnPointerOver"
                                  DataContext="{x:Bind}"
                                  IsAddTabButtonVisible="True"
                                  SelectedItem="{x:Bind ViewModel.ActiveFile, Mode=TwoWay}"
                                  SelectionChanged="DocumentTabs_SelectionChanged"
                                  TabCloseRequested="DocumentTabs_TabClosing"
                                  TabItemsSource="{x:Bind ViewModel.OpenFiles, Mode=OneWay}"
                                  TabWidthMode="Equal">
                        <muxc:TabView.Resources>
                            <x:Double x:Key="TabViewItemHeaderMinHeight">32</x:Double>
                            <x:Double x:Key="TabViewItemHeaderMinWidth">90</x:Double>
                        </muxc:TabView.Resources>
                        <muxc:TabView.TabItemTemplate>
                            <DataTemplate x:DataType="models:XamlDocument">
                                <muxc:TabViewItem HorizontalContentAlignment="Stretch" ContextFlyout="{StaticResource TabItemFlyout}">
                                    <muxc:TabViewItem.Header>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{x:Bind Title, Mode=OneWay}" />
                                            <controls:SwitchPresenter Grid.Column="1"
                                                                      TargetType="models:SyncStatus"
                                                                      Value="{x:Bind State.RenderState, Mode=OneWay}">
                                                <!--  TODO: Placeholders, should have Tooltips too, add to resw  -->
                                                <controls:Case Value="Unrendered">
                                                    <TextBlock Text="⚫" />
                                                </controls:Case>
                                                <controls:Case Value="Error">
                                                    <TextBlock Text="🛑" />
                                                </controls:Case>
                                                <controls:Case Value="OutOfSync">
                                                    <TextBlock Text="🟡" />
                                                </controls:Case>
                                                <controls:Case Value="Synced">
                                                    <TextBlock Text="✅" />
                                                </controls:Case>
                                            </controls:SwitchPresenter>
                                        </Grid>
                                    </muxc:TabViewItem.Header>
                                </muxc:TabViewItem>
                            </DataTemplate>
                        </muxc:TabView.TabItemTemplate>
                    </muxc:TabView>
                </controls:Case>
            </controls:SwitchPresenter>
        </Grid>


        <!--  Main Window Content  -->
        <controls:SwitchPresenter Grid.Row="1"
                                  Grid.Column="2"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ex:FrameworkElementExtensions.AncestorType="muxc:TabView"
                                  TargetType="x:String"
                                  Value="{x:Bind ViewModel.OpenActivity, Mode=OneWay}">
            <controls:Case Value="WELCOME">
                <local:WelcomePage HorizontalAlignment="Stretch" MainViewModel="{x:Bind ViewModel}" />
            </controls:Case>
            <controls:Case Value="SETTINGS">
                <local:SettingsPanelPage HorizontalAlignment="Stretch" MainViewModel="{x:Bind ViewModel}" />
            </controls:Case>
            <!--  Document  -->
            <controls:Case IsDefault="True">
                <future:SelectedContentControl HorizontalAlignment="Stretch"
                                               VerticalAlignment="Stretch"
                                               ItemsSource="{x:Bind ViewModel.OpenFiles, Mode=OneWay}"
                                               SelectedItem="{x:Bind ViewModel.ActiveFile, Mode=OneWay}">
                    <future:SelectedContentControl.ItemTemplate>
                        <DataTemplate x:DataType="models:XamlDocument">
                            <local:Document x:Name="Document"
                                            HorizontalAlignment="Stretch"
                                            ViewModel="{Binding Converter={StaticResource DocumentToViewModelConverter}}" />
                        </DataTemplate>
                    </future:SelectedContentControl.ItemTemplate>
                </future:SelectedContentControl>
            </controls:Case>
        </controls:SwitchPresenter>
    </Grid>
</Page>
