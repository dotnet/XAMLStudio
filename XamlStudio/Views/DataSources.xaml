<Page x:Class="XamlStudio.Views.DataSources"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="using:XamlStudio.Views"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:monaco="using:Monaco"
      mc:Ignorable="d">

    <Grid Background="{ThemeResource Brush-Blue-Dark-1}">
        <Grid.RowDefinitions>
            <RowDefinition Height="54" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Margin="0,0,-12,0"
                Padding="0,12,0,0"
                Style="{StaticResource VSCodeAppBarHeaderStyle}">
            <TextBlock x:Uid="DataSource_Header" Style="{StaticResource VSCodeAppBarHeaderTextStyle}"/>
        </Border>

        <TextBox x:Name="LiveDataSourceUri"
                 Grid.Row="1"
                 Margin="24,12,0,24"
                 Header="REST Url:"
                 LostFocus="LiveDataSourceUri_LostFocus" />
        <monaco:CodeEditor x:Name="DataContextJson"
                           Grid.Row="2"
                           CodeLanguage="json"
                           RequestedTheme="{x:Bind MainViewModel.SettingsViewModel.Settings.EditorTheme, Mode=OneWay}" />
    </Grid>
</Page>
