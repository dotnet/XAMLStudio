<Page
    x:Class="XamlStudio.Views.Explorer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:XamlStudio.Views"
    xmlns:model="using:XamlStudio.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:xc="using:WinRTXamlToolkit.Controls"
    xmlns:controls="using:Microsoft.Toolkit.Uwp.UI.Controls"
    xmlns:future="using:Microsoft.Toolkit.Uwp.UI.Controls.Future"
    xmlns:fex="using:Microsoft.Toolkit.Uwp.UI.Extensions.Future"
    xmlns:converters="using:Microsoft.Toolkit.Uwp.UI.Converters"
    mc:Ignorable="d">

    <!--<Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///WinRTXamlToolkit/Controls/TreeView/TreeViewMouse.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>-->

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="{Binding ElementName=OpenEditorsExpander, Path=IsExpanded, Converter={StaticResource BoolToGridLength}}"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Style="{StaticResource VSCodeAppBarHeaderStyle}"
                Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Style="{StaticResource VSCodeAppBarHeaderTextStyle}">EXPLORER</TextBlock>
                <Button Grid.Column="1" Style="{StaticResource VSCodeAppBarHeaderButtonStyle}"
                        Command="{x:Bind MainViewModel.OpenDocumentCommand}">
                    <SymbolIcon Symbol="OpenFile" fex:SymbolIconExtensions.FontSize="12" />
                </Button>
                <Button Grid.Column="2" Style="{StaticResource VSCodeAppBarHeaderButtonStyle}"
                        Command="{x:Bind MainViewModel.NewDocumentCommand}">
                    <SymbolIcon Symbol="Add" fex:SymbolIconExtensions.FontSize="12" />
                </Button>
            </Grid>
        </Border>
        <controls:Expander x:Name="OpenEditorsExpander"
                           Header="OPEN EDITORS" IsExpanded="True"
                           VerticalContentAlignment="Top"
                           Grid.Row="1">
            <ListBox ItemsSource="{x:Bind MainViewModel.OpenFiles}" SelectedItem="{x:Bind MainViewModel.ActiveFile, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="model:XamlDocument">
                        <TextBlock Text="{Binding Title}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </controls:Expander>
        <future:SwitchPresenter x:Name="FolderExpander"
                                Grid.Row="2">
            <future:Case IsDefault="True">
                <controls:Expander Header="NO FOLDER OPENED" IsExpanded="True">
                    <StackPanel Margin="16">
                        <TextBlock>You have not yet opened a folder.</TextBlock>
                        <Button Margin="0,8,0,0">Open Folder</Button>
                    </StackPanel>
                </controls:Expander>
            </future:Case>
            <future:Case Value="True">
                <controls:Expander Header="{Binding FolderName}">
                    <xc:TreeView/>
                </controls:Expander>
            </future:Case>
        </future:SwitchPresenter>
    </Grid>
</Page>
