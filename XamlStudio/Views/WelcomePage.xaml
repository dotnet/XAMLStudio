<Page
    x:Class="XamlStudio.Views.WelcomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:XamlStudio.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:storage="using:Windows.Storage"
    xmlns:i="using:Microsoft.Xaml.Interactivity"
    xmlns:ic="using:Microsoft.Xaml.Interactions.Core"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Padding="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.ColumnSpan="2" Margin="-68,-16,0,8">
            <Image Source="ms-appx:///Assets/SplashScreen.scale-100.png" Width="300"/>
            <StackPanel Padding="16" HorizontalAlignment="Left"
                                     VerticalAlignment="Center" Margin="-60,0,0,0">
                <TextBlock FontSize="16">a Microsoft Garage project</TextBlock>
                <TextBlock FontSize="16">For Rapid Prototyping</TextBlock>
            </StackPanel>
        </StackPanel>
        <StackPanel Grid.Row="1" Padding="12">
            <TextBlock FontSize="24" FontWeight="Light">Get Started</TextBlock>
            <StackPanel Padding="12">
                <HyperlinkButton Command="{x:Bind MainViewModel.NewDocumentCommand, Mode=OneWay}">New file</HyperlinkButton>
                <HyperlinkButton Command="{x:Bind MainViewModel.OpenDocumentCommand, Mode=OneWay}">Open file...</HyperlinkButton>
            </StackPanel>
        </StackPanel>
        <StackPanel Grid.Row="2">
            <TextBlock FontSize="24" FontWeight="Light" Padding="12">Recent Files</TextBlock>
            <ItemsControl x:Name="RecentFileList"
                          Margin="24,0,0,0"
                          DataContext="{x:Bind}"
                          ItemsSource="{x:Bind RecentFiles}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="storage:StorageFile">
                        <HyperlinkButton Content="{x:Bind DisplayName}" ToolTipService.ToolTip="{x:Bind Path}"
                                         Command="{Binding DataContext.MainViewModel.OpenFileCommand, ElementName=RecentFileList}"
                                         CommandParameter="{x:Bind}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
        <StackPanel Grid.Row="1" Grid.Column="1" Grid.RowSpan="2">
            <TextBlock FontSize="24" FontWeight="Light" Padding="12">Known Issues</TextBlock>
            <!--<TextBlock Padding="12,8">- Tabs disappear if window too small.</TextBlock> Note: Will reappear if we try and add Edge Pivot Styling, so that needs fixing. #586 -->
            <TextBlock Padding="12,8">- Compile errors don't display in the right place in the editor
                <LineBreak/>&#160;&#160;when binding debugging enabled.</TextBlock>
            <TextBlock Padding="12,8">- Not all toolbox items on left navigation implemented.</TextBlock>
            <TextBlock Padding="12,8">- No 'Save As'.</TextBlock>
            <TextBlock Padding="12,8">- Known Namespaces in Settings not configurable.</TextBlock>
            <TextBlock Padding="12,8">- Bindings with ConverterParameters can't be debugged.</TextBlock>
        </StackPanel>
    </Grid>
</Page>
