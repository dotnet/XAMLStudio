<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
                    xmlns:local="using:XamlStudio.Toolkit.Controls">

    <local:ColorToHexConverter x:Key="ColorToHexConverter" />

    <converters:StringFormatConverter x:Key="StringFormatConverter" />

    <DataTemplate x:Key="AcrylicBrushTemplate">
        <Border Width="128"
                Height="128"
                HorizontalAlignment="Left"
                Background="{Binding}" />
    </DataTemplate>

    <!--  TODO: Share with SolidColorBrushTemplate?  -->
    <DataTemplate x:Key="ColorTemplate">
        <Grid>
            <Grid.Resources>
                <SolidColorBrush x:Key="ColorBrush" Color="{Binding}" />
            </Grid.Resources>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Border Width="64"
                    Height="64"
                    Margin="0,8,16,8"
                    Background="{StaticResource ColorBrush}" />
            <TextBlock Grid.Column="1"
                       VerticalAlignment="Center"
                       Text="{Binding Converter={StaticResource ColorToHexConverter}}" />
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="DataTemplateTemplate">
        <ContentPresenter ContentTemplate="{Binding}" />
    </DataTemplate>

    <DataTemplate x:Key="FontFamilyTemplate">
        <TextBlock FontFamily="{Binding}"
                   FontSize="20"
                   Text="Quickly the XAML dev jumps on board for amazing UIs, wow!"
                   TextWrapping="WrapWholeWords" />
    </DataTemplate>

    <DataTemplate x:Key="GridLengthTemplate">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1" />
                <ColumnDefinition x:Name="Column" Width="{Binding}" />
                <ColumnDefinition Width="1" />
            </Grid.ColumnDefinitions>
            <Rectangle Grid.Column="0"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"
                       Fill="Red" />
            <!--  TODO: ToString  -->
            <TextBlock Grid.Column="1"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Text="{Binding Converter={StaticResource StringFormatConverter}, ConverterParameter='{}{0}'}" />
            <Rectangle Grid.Column="3"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"
                       Fill="Red" />
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="SolidColorBrushTemplate">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Border Width="64"
                    Height="64"
                    Margin="0,8,16,8"
                    Background="{Binding}" />
            <TextBlock Grid.Column="1"
                       VerticalAlignment="Center"
                       Text="{Binding Color, Converter={StaticResource ColorToHexConverter}}" />
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="ThicknessTemplate">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Grid.Row="1"
                    Grid.Column="1"
                    Width="160"
                    Height="80"
                    HorizontalAlignment="Left"
                    Background="#E3C381"
                    BorderBrush="White"
                    BorderThickness="1">
                <Border Margin="{Binding}" Background="#88B2BD">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="Black"
                               Text="{Binding Converter={StaticResource StringFormatConverter}, ConverterParameter='{}{0}'}" />
                </Border>
            </Border>
            <TextBlock Grid.Row="1"
                       Margin="0,0,8,0"
                       VerticalAlignment="Center"
                       Text="{Binding Left}" />
            <TextBlock Grid.Column="1"
                       Margin="2"
                       HorizontalAlignment="Center"
                       Text="{Binding Top}" />
            <TextBlock Grid.Row="1"
                       Grid.Column="2"
                       Margin="8,0,0,0"
                       VerticalAlignment="Center"
                       Text="{Binding Right}" />
            <TextBlock Grid.Row="2"
                       Grid.Column="1"
                       Margin="2"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Text="{Binding Bottom}" />
        </Grid>
    </DataTemplate>
</ResourceDictionary>
