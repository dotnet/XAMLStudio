<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:XamlStudio.Toolkit.Controls">

    <local:ColorToHexConverter x:Key="ColorToHexConverter"/>

    <DataTemplate x:Key="SolidColorBrushTemplate">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Border Background="{Binding}" Width="64" Height="64" Margin="8"/>
            <TextBlock Text="{Binding Color,Converter={StaticResource ColorToHexConverter}}" Grid.Column="1"/>
        </Grid>
    </DataTemplate>
</ResourceDictionary>
