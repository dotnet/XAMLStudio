<Page x:Class="XamlStudio3.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:XamlStudio3"
      xmlns:controls="using:CommunityToolkit.WinUI.Controls"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    <Grid>
        <Grid.Resources>
            <Style TargetType="controls:HeaderedContentControl">
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontSize" Value="16"/>
            </Style>
            
            <Style TargetType="TextBox">
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="VerticalAlignment" Value="Stretch"/>
                <Setter Property="AcceptsReturn" Value="True"/>
                <Setter Property="Margin" Value="0,4,0,0"/>
                <Setter Property="FontWeight" Value="Normal"/>
                <Setter Property="FontSize" Value="20"/>
                <Setter Property="FontFamily" Value="Cascadia Code, Consolas, Courier New"/>
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <!-- GridSplitter -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MaxWidth="300"/>
            <!-- GridSplitter -->
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <!-- GridSplitter -->
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Col 0 Readme -->
        <!-- TODO: Make this a collapsable panel w/ ContentSizer ala XAML Studio -->
        <controls:HeaderedContentControl Header="Readme" Grid.RowSpan="3">
            <TextBlock Text="Placeholder text for Markdown / Instructions..." TextWrapping="WrapWholeWords"/>
        </controls:HeaderedContentControl>

        <controls:GridSplitter Grid.Column="1" Grid.RowSpan="3" Orientation="Vertical" ResizeBehavior="PreviousAndNext"/>

        <!-- Col 1 XAML + C# -->
        <controls:HeaderedContentControl Header="XAML Page" Grid.Column="2">
            <TextBox x:Name="XamlMarkup"/>
        </controls:HeaderedContentControl>

        <controls:GridSplitter Grid.Column="2" Grid.Row="1" Orientation="Horizontal" ResizeBehavior="PreviousAndNext"/>

        <controls:HeaderedContentControl Header="C# ViewModel" Grid.Column="2" Grid.Row="2">
            <TextBox x:Name="CSharpCode"/>
        </controls:HeaderedContentControl>

        <controls:GridSplitter Grid.Column="3" Grid.RowSpan="3" Orientation="Vertical" ResizeBehavior="PreviousAndNext"/>

        <!-- Col 2 XAML Resources + Result -->
        <controls:HeaderedContentControl Header="XAML Resources" Grid.Column="4">
            <TextBox x:Name="XamlResourceMarkup"/>
        </controls:HeaderedContentControl>

        <controls:GridSplitter Grid.Column="4" Grid.Row="1" Orientation="Horizontal" ResizeBehavior="PreviousAndNext"/>

        <controls:HeaderedContentControl Header="Result" Grid.Column="4" Grid.Row="2">
            <Border x:Name="ResultRoot"/>
        </controls:HeaderedContentControl>
    </Grid>
</Page>
